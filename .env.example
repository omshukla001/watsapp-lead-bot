# Server
PORT=3000
NODE_ENV=development

# MongoDB (use MongoDB Atlas — free tier works fine on phone)
MONGO_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/whatsapp_lead_bot

# Cerebras AI
CEREBRAS_API_KEY=your_cerebras_api_key_here
CEREBRAS_API_URL=https://api.cerebras.ai/v1/chat/completions
CEREBRAS_MODEL=llama-3.3-70b

# Admin dashboard (HTTP Basic Auth — username can be anything)
ADMIN_PASSWORD=change_me

# Termux notifications (set to "false" to disable phone notifications/vibration on new leads)
TERMUX_NOTIFY=true

# Logging
LOG_LEVEL=info
